                <Button fx:id="ilMioProfiloButton" styleClass="profile-button" text="Il mio profilo" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="15.0" />
            </children>
        </AnchorPane>
    </top>

    <left>
        <VBox prefHeight="375.0" prefWidth="147.0" spacing="10.0">
            <Button fx:id="homeButton" text="Home" maxWidth="Infinity" styleClass="sidebar-button" />
